# Stryper Events - Environment Variables Template
# Copy this file to .env.local and fill in your actual values

# Site Configuration
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME="Stryper Event Management"

# Contact Information
NEXT_PUBLIC_PHONE="+91 XXX XXX XXXX"
NEXT_PUBLIC_EMAIL="deepak.shah@stryperevent.com"
NEXT_PUBLIC_WHATSAPP="+91XXXXXXXXXX"
NEXT_PUBLIC_ADDRESS="Jaipur, Rajasthan, India"

# Email Service (Choose one)
# Option 1: SendGrid
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM_EMAIL=noreply@stryperevent.com

# Option 2: Resend
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=noreply@stryperevent.com

# Option 3: SMTP (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# Notification Email (where form submissions are sent)
NOTIFICATION_EMAIL=admin@stryperevent.com

# Analytics (Optional)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# Social Media Links (Optional)
NEXT_PUBLIC_FACEBOOK_URL=https://facebook.com/stryperevent
NEXT_PUBLIC_INSTAGRAM_URL=https://instagram.com/stryperevent
NEXT_PUBLIC_LINKEDIN_URL=https://linkedin.com/company/stryperevent
NEXT_PUBLIC_TWITTER_URL=https://twitter.com/stryperevent

# Database (Optional - for storing form submissions)
DATABASE_URL=postgresql://user:password@localhost:5432/stryper_events

# Security
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your_recaptcha_site_key
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key
